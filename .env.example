# Server Config
PORT=5000
NODE_ENV=development

# Frontend CORS URL (split by commas)
FRONTEND_URL=http://localhost:3000,https://a1-learner.vercel.app

# MongoDB Configuration (Atlas or Local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/a1_learner

# JWT Security secrets
JWT_SECRET=your_jwt_access_secret_key
JWT_EXPIRE=30m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_REFRESH_EXPIRE=7d

# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here
